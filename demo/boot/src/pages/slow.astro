---
import '../styles/index.css';
import Layout from '../../../shared/Layout.astro';
import { getHeartbeatCount } from '../server/some-module';

// simulate a slow request still rendering when a restart fires.
// in production this is e.g. a slow upstream API or a streaming render.
await new Promise((resolve) => setTimeout(resolve, 2000));

// touches a user singleton — if onShutdown has already disposed it,
// this throws and Astro logs the error.
const heartbeats = getHeartbeatCount();
---

<Layout title="Slow" package="@astroscope/boot">
  <p>heartbeats: {heartbeats}</p>
</Layout>
