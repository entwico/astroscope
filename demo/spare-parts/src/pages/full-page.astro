---
import '../styles/index.css';
import type { WebpageMetadata } from '@astroscope/spare-parts';
import { Page } from '@astroscope/spare-parts/astro';

const metadata: WebpageMetadata = {
  title: 'Full Page Demo · spare-parts',
  description: 'A complete document rendered by <Page> — head metadata, og/twitter tags, hreflang, bfcache.',
  canonical: Astro.originPathname,
  ogImage: '/og.png',
  twitterCard: 'summary_large_image',
  alternates: [
    { hreflang: 'en', href: 'https://example.com/en' },
    { hreflang: 'de', href: 'https://example.com/de' },
  ],
};
---

<Page lang="en" siteName="Spare Parts Co" bodyClass="min-h-screen bg-base-200 p-4" disableBfCache {...metadata}>
  <link slot="head-early" rel="preconnect" href="https://fonts.example.com" />
  <link slot="head" rel="icon" href="/favicon.svg" />

  <div class="mx-auto max-w-4xl space-y-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">&lt;Page&gt; — the full document</h1>
      <div class="badge badge-primary mt-2">@astroscope/spare-parts</div>
    </header>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title">View source 👀</h2>
        <p>This whole document — <code>&lt;html&gt;</code> down — is rendered by <code>&lt;Page&gt;</code>. Its <code>&lt;head&gt;</code> contains:</p>
        <ul class="list-disc list-inside space-y-1">
          <li><code>charset</code> + <code>viewport</code></li>
          <li>title, description, robots, and an absolutized <code>&lt;link rel="canonical"&gt;</code></li>
          <li>the full <code>og:*</code> set <strong>including <code>og:url</code></strong>, plus <code>twitter:card</code></li>
          <li><code>&lt;link rel="alternate" hreflang&gt;</code> for <code>en</code> / <code>de</code></li>
          <li>your <code>head-early</code> <code>preconnect</code> and <code>head</code> favicon</li>
        </ul>
        <p>
          <code>disableBfCache</code> also set a <code>Cache-Control: no-store</code> response header (check the network
          tab) plus a <code>pageshow</code> reload guard — for checkout / auth pages.
        </p>
        <a class="link link-primary" href="/">← back to the parts</a>
      </div>
    </div>
  </div>
</Page>
