{
  "name": "@astroscope/node",
  "version": "1.3.0",
  "description": "Opinionated, cloud-friendly Node adapter for Astro: boot lifecycle, health probes, request logging, telemetry, CSRF and static serving run as plain code around server.listen()",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./health": {
      "types": "./dist/health.d.ts",
      "import": "./dist/health.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./boot": {
      "types": "./dist/boot.d.ts",
      "import": "./dist/boot.js"
    },
    "./excludes": {
      "types": "./dist/excludes.d.ts",
      "import": "./dist/excludes.js"
    },
    "./log": {
      "types": "./dist/log/index.d.ts",
      "import": "./dist/log/index.js"
    },
    "./events": {
      "types": "./dist/lifecycle/events.d.ts",
      "import": "./dist/lifecycle/events.js"
    },
    "./csrf-middleware": {
      "types": "./dist/csrf-middleware-entrypoint.d.ts",
      "import": "./dist/csrf-middleware-entrypoint.js"
    },
    "./dev-middleware": {
      "types": "./dist/dev-middleware-entrypoint.d.ts",
      "import": "./dist/dev-middleware-entrypoint.js"
    },
    "./route-middleware": {
      "types": "./dist/route-middleware-entrypoint.d.ts",
      "import": "./dist/route-middleware-entrypoint.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/astroscope",
    "directory": "packages/node"
  },
  "keywords": [
    "astro",
    "astro-adapter",
    "astro-integration",
    "node",
    "frameworks"
  ],
  "author": "admin@entwico.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/entwico/astroscope/issues"
  },
  "homepage": "https://github.com/entwico/astroscope/tree/main/packages/node#readme",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --cache",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.3.1",
    "@entwico/dash": "^1.3.0",
    "@entwico/health-probes": "^1.1.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/host-metrics": "^0.39.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.33.0",
    "@opentelemetry/instrumentation-undici": "^0.30.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "acorn": "^8.17.0",
    "magic-string": "^0.30.21",
    "pino": "^10.3.1",
    "send": "^1.2.1"
  },
  "devDependencies": {
    "@types/send": "^1.2.1",
    "astro": "^7.0.9",
    "tsdown": "^0.22.8",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "astro": "^7.0.0",
    "vite": "^8.0.0"
  }
}
