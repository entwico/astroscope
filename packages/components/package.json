{
  "name": "@astroscope/components",
  "version": "1.0.0",
  "description": "Reusable Astro components for common page needs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./astro": {
      "import": "./src/astro/index.ts"
    }
  },
  "files": [
    "dist",
    "src/astro",
    "src/index.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/astroscope",
    "directory": "packages/components"
  },
  "keywords": [
    "astro",
    "seo",
    "json-ld",
    "schema-org",
    "open-graph",
    "components"
  ],
  "author": "admin@entwico.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/entwico/astroscope/issues"
  },
  "homepage": "https://github.com/entwico/astroscope/tree/main/packages/components#readme",
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --no-fixed-extension",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --cache",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "astro": "^7.0.9",
    "tsdown": "^0.22.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  }
}
