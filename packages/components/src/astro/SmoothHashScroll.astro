---
// intercept plain left-clicks on same-page hash links and smoothly scroll to the target
---

<script is:inline>
  document.body.addEventListener('click', (event) => {
    if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
      return;
    }

    let target = event.target;

    while (target && target !== document.body) {
      if (target.tagName === 'A') {
        const raw = target.getAttribute('href') || '';
        let hash = '';

        if (raw.startsWith('#')) {
          hash = raw;
        } else if (target.href.startsWith(`${window.location.origin}${window.location.pathname}#`)) {
          hash = new URL(target.href).hash;
        }

        if (hash.length > 1) {
          let id;

          try {
            id = decodeURIComponent(hash.slice(1));
          } catch {
            id = hash.slice(1);
          }

          const el = document.getElementById(id);

          if (el) {
            event.preventDefault();

            if (hash !== window.location.hash) {
              history.pushState(null, '', hash);
            }

            el.scrollIntoView({ behavior: 'smooth' });
          }
        }

        return;
      }

      target = target.parentNode;
    }
  });
</script>
