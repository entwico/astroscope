{
  "name": "@astroscope/proxy",
  "version": "0.4.0",
  "description": "HTTP proxy for Astro — strangler fig migrations and API gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "astro": {
    "external": true
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/astroscope",
    "directory": "packages/proxy"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "proxy",
    "http-proxy",
    "reverse-proxy",
    "migration",
    "strangler-fig",
    "frameworks"
  ],
  "author": "admin@entwico.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/entwico/astroscope/issues"
  },
  "homepage": "https://github.com/entwico/astroscope/tree/main/packages/proxy#readme",
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --no-fixed-extension",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --cache",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "astro": "^7.0.9",
    "tsdown": "^0.22.8",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  }
}
