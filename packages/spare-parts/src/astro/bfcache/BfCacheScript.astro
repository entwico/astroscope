---
// the client half of the bfcache opt-out. the server half is the `Cache-Control` header, which
// must be set from a component whose frontmatter runs before the response streams (Page / WithNoBfCache).
//
// pageshow with persisted=true means the page was restored from bfcache → force a fresh load.
// registering a pagehide handler is enough to opt some browsers out of bfcache.
//
// comments live here, not in the inline script below, which ships to the browser verbatim.
---

<script is:inline>
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      window.location.reload();
    }
  });

  window.addEventListener('pagehide', () => {});
</script>
