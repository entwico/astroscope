---
interface Props {
  data: unknown;
  type?: string | undefined;
  id?: string | undefined;
}

const { data, type = 'application/json', id } = Astro.props;

// escape `<` so a value containing `</script>` (or `<!--`) can't break out of the
// inline script. astro has no native safe way to render a data `<script>` block —
// `define:vars` only works on executable scripts, not `type="application/ld+json"`.
const json = JSON.stringify(data).replaceAll('<', '\\u003c');
const attrs = `type="${type}"${id ? ` id="${id}"` : ''}`;
---

<Fragment set:html={`<script ${attrs}>${json}</script>`} />
